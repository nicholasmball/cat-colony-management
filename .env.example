# Copy to .env.local for local dev. NEVER commit real values.
# Real values live in Vercel (app) and the Supabase dashboard.

# Supabase — public (safe to expose to the browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only service role key. BYPASSES RLS. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=pt

# Service worker / offline-first (PWA). Both default off (unset). Only the exact
# string "true" arms a flag (see lib/offline/sw-flags.ts).
NEXT_PUBLIC_SW_ENABLED=  # "true" = register the offline service worker (Phase 3)
NEXT_PUBLIC_SW_KILL=     # "true" = emergency: unregister all SWs + clear caches

# Alert engine cron — bearer secret guarding POST /api/cron/alerts AND
# POST /api/cron/email-digest. Scheduled via Supabase pg_cron + pg_net with this
# secret (alerts ~every 15 min; the email digest daily — the digest job is NOT
# scheduled until the email layer is armed; see docs/email-setup.md).
CRON_SECRET=

# Transactional email — provider-agnostic, FLAG-GATED + armed-ready. The layer is
# a typed no-op (logs "email.skipped", never throws) UNLESS BOTH EMAIL_ENABLED is
# exactly "true" AND RESEND_API_KEY is set (see lib/email/flags.ts). Reset/confirm
# emails are owned by Supabase Auth SMTP, NOT this layer. Full arm-it checklist +
# the swap-to-SCoT note: docs/email-setup.md.
EMAIL_ENABLED=          # "true" = arm the email layer (needs a key below too)
RESEND_API_KEY=         # Resend API key (Nick's account at deploy; swap later)
EMAIL_FROM=             # e.g. "Street Cats of Tavira <no-reply@app.streetcatsoftavira.org>"

# Added by later tasks (kept here as a reference of what's coming):
# SMS (Twilio) — TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN / TWILIO_FROM_NUMBER
# Web push (VAPID) — NEXT_PUBLIC_VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY
